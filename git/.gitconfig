# This is Git's per-user configuration file.
[user]
	name = Dylan Landman
	email = dylan.landman@chalkboard.io
# Please adapt and uncomment the following lines:
#	name = Dylan Landman
#	email = dylan.landman@chalkboard.io
[push]
	autoSetupRemote = true
[alias]
	rebranch = "!f() { git checkout \"$2\" && git pull && git branch -D \"$1\" && git checkout -b \"$1\"; }; f"
	grb = "!f() { git rebranch \"$@\"; }; f"
