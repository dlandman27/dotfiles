# Install everything with:  brew bundle --file=~/dotfiles/Brewfile

# Core
brew "git"
brew "gh"          # GitHub CLI — used by gprc

# Shell tools
brew "gum"         # TUI toolkit — used by bin/sim

# Version managers (referenced in zsh/.zshrc)
brew "nvm"
brew "rbenv"
brew "ruby-build"

# AI helpers (zsh/ai.zsh, gprc) shell out to the `claude` CLI
cask "claude-code"
